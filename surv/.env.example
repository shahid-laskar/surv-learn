# ════════════════════════════════════════════════════════════════════════════
# Sarvanetra — root .env
# VM IP: 10.44.0.209 — used anywhere a URL is returned to the browser
# (frontend, HLS, WebRTC, MinIO presigned URLs). Internal Docker service
# names (postgres, surv_kafka, minio, mediamtx) are used for container-to-
# container calls and never need to change.
# ════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=surv
POSTGRES_PASSWORD=changeme
POSTGRES_DB=sarvanetra
POSTGRES_PORT=5432

# Sync URL — used by workers (onvif_producer, motion_consumer, status_monitor,
# segment_db_consumer) and by Alembic migrations
DATABASE_URL=postgresql://surv:changeme@postgres:5432/sarvanetra
SYNC_DATABASE_URL=postgresql://surv:changeme@postgres:5432/sarvanetra

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme123
# Internal endpoint — used by FastAPI/workers calling MinIO inside Docker
MINIO_ENDPOINT=minio:9000
# External endpoint — used to SIGN presigned URLs your browser will open.
# Must be the VM IP, not localhost and not the internal minio:9000 name.
MINIO_EXTERNAL_URL=http://10.44.0.209:9000
MINIO_BUCKET_RECORDINGS=recordings
MINIO_BUCKET_SNAPSHOTS=snapshots

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_PORT=9092
KAFKA_UI_PORT=8090
# Matches KAFKA_ADVERTISED_LISTENERS in the kafka service — container name,
# used by every service that talks to Kafka internally
KAFKA_BOOTSTRAP_SERVERS=surv_kafka:9092

# ── MediaMTX ──────────────────────────────────────────────────────────────────
MEDIAMTX_RTSP_PORT=8554
MEDIAMTX_HLS_PORT=8888
MEDIAMTX_WEBRTC_PORT=8889
MEDIAMTX_API_PORT=9997
SEGMENT_DURATION_SECONDS=60
# Internal API — FastAPI calls this inside the Docker network
MEDIAMTX_API_URL=http://mediamtx:9997
# Returned to the BROWSER — must be the VM IP
MEDIAMTX_HLS_BASE=http://10.44.0.209:8080/hls
MEDIAMTX_WEBRTC_BASE=http://10.44.0.209:8889

# ── ONVIF cameras ────────────────────────────────────────────────────────────
ONVIF_USERNAME=admin
ONVIF_PASSWORD=admin
ONVIF_PORT=80

# Comma-separated camera paths used by the snapshotter
CAMERA_PATHS=CAMKRTVM00001

# ── FastAPI / Auth ───────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-64-char-random-hex-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
DEBUG=false

# ── Frontend build args (passed to Dockerfile.frontend) ──────────────────────
# Baked into the JS bundle at build time — also must be the VM IP
VITE_API_BASE_URL=http://10.44.0.209:8000/api/v1
VITE_HLS_BASE=http://10.44.0.209:8080/hls
VITE_WEBRTC_BASE=http://10.44.0.209:8889
